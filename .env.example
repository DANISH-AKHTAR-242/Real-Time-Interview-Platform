# Shared infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_platform?schema=public
REDIS_URL=redis://localhost:6379

# Shared runtime controls (each service reads these if present)
HOST=0.0.0.0
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=15000
BODY_LIMIT_BYTES=1048576
TRUST_PROXY=false
SHUTDOWN_GRACE_PERIOD_MS=10000

# Auth-service settings
# Start auth-service with: PORT=3001 pnpm --filter=@repo/auth-service dev
JWT_EXPIRES_IN=900
MAX_AUTH_ATTEMPTS_PER_MINUTE=20
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_RSA_PRIVATE_KEY\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_RSA_PUBLIC_KEY\n-----END PUBLIC KEY-----"

# Session-service settings
# Start session-service with: PORT=3003 pnpm --filter=@repo/session-service dev

# Collab-service settings
# Start collab-service with: PORT=3002 pnpm --filter=@repo/collab-service dev
SESSION_SERVICE_URL=http://localhost:3003
SESSION_SERVICE_TIMEOUT_MS=4000
ALLOW_MOCK_SESSION_ACCESS=false
MAX_PAYLOAD_BYTES=1048576

# Frontend settings
VITE_WS_URL=ws://localhost:3002
